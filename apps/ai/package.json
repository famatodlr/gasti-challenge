{
  "name": "ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./mastra": {
      "types": "./dist/mastra/index.d.ts",
      "import": "./dist/mastra/index.js"
    }
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "bun run build:package && MASTRA_TELEMETRY_DISABLED=1 bun node_modules/mastra/dist/index.js build",
    "build:package": "tsc -p tsconfig.build.json",
    "test:agents": "bun test src/mastra/agents/*.test.ts",
    "test:domain": "bun test src/mastra/domain/*.test.ts",
    "test:tools": "bun test src/mastra/tools/finance-tools.test.ts",
    "test:workflows": "bun test src/mastra/workflows/*.test.ts",
    "verify:domain": "node src/mastra/domain/verify-analytics.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@mastra/core": "^0.10.0",
    "@mastra/libsql": "^0.10.0",
    "@mastra/memory": "^0.10.0",
    "mastra": "^0.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
}
